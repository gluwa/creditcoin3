{
    "name": "creditcoin3-scripts",
    "version": "1.0.0",
    "description": "Utility scripts for Creditcoin3 project",
    "type": "commonjs",
    "scripts": {
        "submit-proof": "node SubmitProof.js",
        "format": "prettier --write \"**/*.js\"",
        "check-format": "prettier --check \"**/*.js\"",
        "lint": "eslint --max-warnings 0 \"**/*.js\"",
        "lint:fix": "eslint --fix \"**/*.js\"",
        "typecheck": "echo"
    },
    "dependencies": {
        "ethers": "^6.16.0",
        "@polkadot/api": "16.5.2"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "3.8.1"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "creditcoin3",
        "blockchain",
        "proof",
        "precompile"
    ],
    "author": "",
    "license": "MIT"
}
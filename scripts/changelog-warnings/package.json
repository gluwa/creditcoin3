{
    "name": "changelog-warnings",
    "version": "1.0.0",
    "description": "Analyzes git diffs and appends operator warnings to changelogs",
    "type": "commonjs",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start": "tsx src/index.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "check-format": "prettier --check \"src/**/*.ts\"",
        "lint": "eslint --max-warnings 0 \"src/**/*.ts\"",
        "lint:fix": "eslint --fix \"src/**/*.ts\""
    },
    "dependencies": {
        "js-yaml": "^4.1.0",
        "minimatch": "^10.2.4"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/minimatch": "^5.1.2",
        "@types/node": "^20.17.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "3.8.1",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT"
}

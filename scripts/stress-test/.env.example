# Proof-Gen API Stress Test Environment Variables
# Copy to .env and fill in actual values:
#   cp .env.example .env

# Required: Proof generation API URL
API_URL=http://localhost:3100

# Required: Chain key
CHAIN_KEY=1

# Required for valid/mixed modes: Source chain HTTP RPC
SOURCE_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Optional: Stress test parameters
# MODE=valid
# RPS=50
# CONCURRENCY=20
# DURATION=60
# MIX_RATIO=0.5
# BLOCK_RANGE=1000-2000

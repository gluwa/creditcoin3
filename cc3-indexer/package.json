{
  "name": "cc3-indexer",
  "version": "1.0.0",
  "description": "cc3-indexer",
  "main": "dist/index.js",
  "scripts": {
    "build": "subql codegen && yarn generate-types && subql build",
    "codegen": "subql codegen && yarn generate-types",
    "start:docker": "docker compose pull && docker compose up --remove-orphans",
    "dev": "subql codegen && subql build && docker compose pull && docker compose up --remove-orphans",
    "prepack": "rm -rf dist && npm run build",
    "test": "subql build && c8 --exclude-after-remap subql-node test",
    "format": "prettier --write \"src/**/*.ts\"",
    "check-format": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint -c .eslintrc.js --max-warnings 0 --ext .ts ./src",
    "typecheck": "echo 'Type checking is disabled b/c of SecondLayerHandlerProcessor_1_0_0'",
    "typecheck:disabled": "yarn codegen && tsc --noEmit",
    "build:develop": "NODE_ENV=develop subql codegen && NODE_ENV=develop subql build",
    "generate-types": "typechain --target=ethers-v5 --out-dir src/types/chain 'abis/*.json'"
  },
  "homepage": "https://github.com/gluwa/creditcoin3-next",
  "repository": "github:gluwa/creditcoin3-next",
  "files": [
    "dist",
    "schema.graphql",
    "project.yaml"
  ],
  "author": "gluwa",
  "license": "MIT",
  "devDependencies": {
    "@polkadot/api": "15.8.1",
    "@subql/cli": "5.5.1",
    "@subql/common-substrate": "4.3.7",
    "@subql/frontier-evm-processor": "^1.0.0",
    "@subql/node": "^5.7.2",
    "@subql/testing": "2.2.3",
    "@subql/types": "3.12.1",
    "@typechain/ethers-v5": "^11.1.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "dotenv": "16.4.7",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "ipfs-unixfs": "6.0.6"
  },
  "dependencies": {
    "package-json-type": "^1.0.3",
    "pino": "^9.6.0",
    "typechain": "^8.3.2"
  }
}

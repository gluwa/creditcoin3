{
  "name": "@creditcoin3/usc-messaging",
  "version": "0.1.0",
  "description": "USC Write-Ability Layer: quoter, dApp ack worker, contracts (attester + relayer are implemented in Rust — see the attestor crate and message-relayer)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "quoter": "node dist/quoter/server.js",
    "dev:quoter": "tsx src/quoter/server.ts",
    "deploy": "cd contracts && ./script/deploy.sh",
    "seed-message": "tsx scripts/seed-message.ts",
    "request-quote": "tsx scripts/request-and-relay-quote.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

# -- Private Keys and URLs -----------------------------------------------------
# Private key used for payments on destination chain
DESTINATION_CHAIN_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# Private key used for payments on Creditcoin (well-known dev account "Alith", 0xf24FF3a9CF04c71Dbc94D0b566f7A27B94566cac, pre-funded in the --dev genesis)
CREDITCOIN_CHAIN_PRIVATE_KEY="0x5fb92d6e98884f76de468fa3f6278f8807c48bebc13595d45af5bdc4da702133"

# RPC URL for the destination chain
DESTINATION_CHAIN_RPC_URL="http://127.0.0.1:8545"

# RPC URL for Creditcoin chain which is the source of our writability messages
CREDITCOIN_RPC_URL="http://127.0.0.1:9944"

# (Optional) Substrate WS RPC for Creditcoin, used by the deploy script to submit the
# supportedChains.setOutboxFactoryAddr extrinsic. Defaults to CREDITCOIN_RPC_URL with its scheme
# switched to ws/wss.
CREDITCOIN_SUBSTRATE_WS_URL=""

# (Optional) SURI of the sudo/operator account used to register the outbox factory on-chain.
# Defaults to the dev sudo account //Alice; override for non-dev chains.
CREDITCOIN_SUDO_SURI="//Alice"

# -- Smart Contract Addresses --------------------------------------------------

# SimpleInbox contract address on the destination chain
INBOX_ADDR=""

# Address of the vote validator contract on the destination chain
VOTE_VALIDATOR_ADDR=""

# Address of the destination contract on the destination chain
DESTINATION_CONTRACT_ADDR=""

# Outbox factory contract address on the Creditcoin chain (USC-operated; creates outboxes)
OUTBOX_FACTORY_ADDR=""

# Outbox contract address on the Creditcoin chain (created by the factory via createOutbox)
OUTBOX_ADDR=""

# AcknowledgmentValidator contract on the Creditcoin chain — the Outbox's `validator`; verifies
# native USC delivery proofs and calls acknowledgeMessage. The off-chain submitter targets this.
ACK_VALIDATOR_ADDR=""

# Address of the relayer contract on the Creditcoin chain
RELAYER_CONTRACT_ADDR=""

# Address of the dApp contract on the Creditcoin chain
DAPP_CONTRACT_ADDR=""

# -- Relayer -------------------------------------------------------

# HTTP port the relayer listens on for attestor submissions
RELAYER_HTTP_PORT=3301

# How often (ms) the delivery worker processes the pending queue
RELAYER_DELIVERY_INTERVAL_MS=5000

# -- Attestor -------------------------------------------------------

# Relayer base URL the attestor posts signed messages to
ATTESTOR_RELAYER_URL="http://127.0.0.1:3301"

# How often (ms) the attestor polls for new Outbox events
ATTESTOR_POLL_INTERVAL_MS=5000

# -- Quoter ------------------------------------------------------------

# Payment token address (0x0...0 for native currency)
QUOTER_PAYMENT_TOKEN="0x0000000000000000000000000000000000000000"

# HTTP port the quoter listens on
QUOTER_PORT=3300

# Quote validity period in seconds
QUOTER_EXPIRY_SECONDS=3600

# Default gas limit for relay delivery
QUOTER_RELAY_GAS_LIMIT=300000

# Gas limit for acknowledgment transactions
QUOTER_ACK_GAS_LIMIT=500000

# Gas buffer multiplier (e.g. 135 = 35% safety margin)
QUOTER_GAS_BUFFER=135

# ── Relayer ───────────────────────────────────────────────────────────────────

# Private key used by the relayer for gas payments
RELAYER_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# RPC URL for the destination chain (where SimpleInbox is deployed)
RELAYER_RPC_URL="http://127.0.0.1:8545"

# RPC URL for the source chain (where Outbox is deployed, used for ACK)
RELAYER_SOURCE_RPC_URL="http://127.0.0.1:9944"

# SimpleInbox contract address on the destination chain
RELAYER_INBOX_ADDRESS="0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512"

# Outbox contract address on the source chain (used for ACK)
RELAYER_OUTBOX_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"

# HTTP port the relayer listens on for attester submissions
RELAYER_HTTP_PORT=3301

# How often (ms) the delivery worker processes the pending queue
RELAYER_DELIVERY_INTERVAL_MS=5000

# ── Attester ──────────────────────────────────────────────────────────────────

# Private key used by the attester to sign messages
ATTESTER_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# RPC URL for the source chain (where Outbox lives)
ATTESTER_SOURCE_RPC_URL="http://127.0.0.1:9944"

# Outbox contract address on the source chain
ATTESTER_OUTBOX_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"

# Relayer base URL the attester posts signed messages to
ATTESTER_RELAYER_URL="http://127.0.0.1:3301"

# How often (ms) the attester polls for new Outbox events
ATTESTER_POLL_INTERVAL_MS=5000

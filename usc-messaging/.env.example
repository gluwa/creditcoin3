# -- Private Keys and URLs -----------------------------------------------------
# Private key used for payments on destination chain
DESTINATION_CHAIN_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# Private key used for payments on Creditcoin
CREDITCOIN_CHAIN_PRIVATE_KEY="0x4d5db4107d237df7c7a0f3c9b7e5e768f8b1a79cd13e341fa9a316bed36fb1d4"

# RPC URL for the destination chain
DESTINATION_CHAIN_RPC_URL="http://127.0.0.1:8545"

# RPC URL for Creditcoin chain which is the source of our writability messages
CREDITCOIN_RPC_URL="http://127.0.0.1:9944"

# -- Smart Contract Addresses --------------------------------------------------

# SimpleInbox contract address on the destination chain
INBOX_ADDR=""

# Address of the vote validator contract on the destination chain
VOTE_VALIDATOR_ADDR=""

# Address of the destination contract on the destination chain
DESTINATION_CONTRACT_ADDR=""

# Outbox contract address on the Creditcoin chain
OUTBOX_ADDR=""

# Address of the relayer contract on the Creditcoin chain
RELAYER_CONTRACT_ADDR=""

# Address of the dApp contract on the Creditcoin chain
DAPP_CONTRACT_ADDR=""

# -- Relayer -------------------------------------------------------

# HTTP port the relayer listens on for attester submissions
RELAYER_HTTP_PORT=3301

# How often (ms) the delivery worker processes the pending queue
RELAYER_DELIVERY_INTERVAL_MS=5000

# -- Attester -------------------------------------------------------

# Relayer base URL the attester posts signed messages to
ATTESTER_RELAYER_URL="http://127.0.0.1:3301"

# How often (ms) the attester polls for new Outbox events
ATTESTER_POLL_INTERVAL_MS=5000

# -- Quoter ------------------------------------------------------------

# Payment token address (0x0...0 for native currency)
QUOTER_PAYMENT_TOKEN="0x0000000000000000000000000000000000000000"

# HTTP port the quoter listens on
QUOTER_PORT=3300

# Quote validity period in seconds
QUOTER_EXPIRY_SECONDS=3600

# Default gas limit for relay delivery
QUOTER_RELAY_GAS_LIMIT=300000

# Gas limit for acknowledgment transactions
QUOTER_ACK_GAS_LIMIT=500000

# Gas buffer multiplier (e.g. 135 = 35% safety margin)
QUOTER_GAS_BUFFER=135

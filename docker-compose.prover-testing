---
volumes:
  prover_data:
  validator_data:

services:
  database:
    container_name: prover-database
    image: postgres:latest
    # only for debugging network connectivity
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - prover_data:/var/lib/postgresql/data
    restart: always
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U prover -d attestations" ]
      interval: 10s
      timeout: 5s
      retries: 5
    environment:
      POSTGRES_DB: attestations
      POSTGRES_USER: prover
      POSTGRES_PASSWORD: creditcoin

  validator:
    container_name: creditcoin-validator
    volumes:
      - validator_data:/creditcoin-node/data
    image: gluwa/creditcoin3-next
    entrypoint: /bin/creditcoin3-node
    command:
      - --dev
      - --validator
      - --pruning
      - archive
      - --node-key
      - d182d503b7dd97e7c055f33438c7717145840fd66b2a055284ee8d768241a463
      - --base-path
      - /creditcoin-node/data
      - --unsafe-rpc-external
    expose:
      - 9944

  prover:
    container_name: creditcoin-prover
    image: gluwa/creditcoin3-next
    depends_on:
      database:
        condition: service_healthy
      validator:
        condition: service_started
    extra_hosts:
      - "host.docker.internal:host-gateway"
    entrypoint: /bin/prover
    command:
      - --verbose
      - --cc3-rpc-url
      - ws://creditcoin-validator:9944
      - --cc3-key
      - "//Alice"
      - --eth-rpc-url
      - http://host.docker.internal:8545
      - --cc3-evm-private-key
      - 5fb92d6e98884f76de468fa3f6278f8807c48bebc13595d45af5bdc4da702133
      - --postgres-uri
      - postgres://prover:creditcoin@prover-database:5432/attestations

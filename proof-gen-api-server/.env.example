# Proof Gen API Server environment variable examples
# Copy this file to .env and adjust values as needed.
# DO NOT commit your personal .env.

# Bind address for the HTTP API server
BIND_ADDR=0.0.0.0:3100

# Creditcoin (cc3) RPC endpoint (websocket / ws / wss)
CC3_RPC_URL=ws://127.0.0.1:9944

# Ethereum (source chain) RPC endpoint
ETH_RPC_URL=http://127.0.0.1:8545

# Mnemonic or seed phrase used by server for chain interactions
# Use development accounts (e.g., //Alice) only in local environments.
CC3_KEY=//Alice

# Source chain key (must match chain registered on Creditcoin)
CHAIN_KEY=1

# (Removed) mock providers flag now provided as a CLI argument: --use-mock-providers

# Logging profile; set to production OR prod in real deployments
RUST_LOG=debug

# Enable Prometheus metrics collection
ENABLE_PROMETHEUS_METRICS=false
PROMETHEUS_HOST=0.0.0.0
PROMETHEUS_PORT=9090

# Postgres connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=proofs_db

# Notes:
# - Set USE_MOCK_PROVIDERS=0 (or remove) for real chain RPC usage.
# - Startup is refused if USE_MOCK_PROVIDERS is truthy and RUST_LOG=production/prod.
# - Never commit real mnemonics or secrets.

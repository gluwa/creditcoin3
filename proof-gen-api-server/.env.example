# Proof Gen API Server environment variable examples
# Copy this file to .env and adjust values as needed.
# DO NOT commit your personal .env.

# Note: The HTTP API server bind address is configured via CLI flags:
#   --bind-host (default: 0.0.0.0)
#   --bind-port (default: 3100)
#
# Multi-chain YAML config (optional). When set, `chains:` in the file replace
# single-chain ETH_RPC_URL / CHAIN_KEY / ARCHIVER_URL below.
PROOF_GEN_CONFIG_FILE=./config.yaml

# Creditcoin3 RPC (WebSocket). Not read from config.yaml — use this or `--cc3-rpc-url`.
CC3_RPC_URL=wss://rpc.usc-devnet.creditcoin.network

# Mnemonic or seed phrase used by server for chain interactions
# Use development accounts (e.g., //Alice) in local and devnet environments. Do NOT use in production.
CC3_KEY=//Alice

# Logging profile; set to production OR prod in real deployments
RUST_LOG=debug

# Enable Prometheus metrics collection
ENABLE_PROMETHEUS_METRICS=false
PROMETHEUS_HOST=0.0.0.0
PROMETHEUS_PORT=9090

# Optional: Redis URL for Ethereum block caching
# REDIS_URL=redis://127.0.0.1:6379
# Optional: Set to true/1/yes when using Redis Cluster (e.g. ElastiCache cluster mode)
# REDIS_CLUSTER_MODE=false

# Optional: CC3 Indexer GraphQL URL for pre-fetching continuity proofs on BlockAttested events
# When set, the server will fetch and cache continuity proofs proactively as attestations occur.
# INDEXER_URL=http://127.0.0.1:3000
# Devnet: https://attestations-graphql.usc-devnet.creditcoin.network
# Testnet: https://attestations-graphql.usc-testnet.creditcoin.network

# Notes:
# - Never commit real mnemonics or secrets.

# Amount of concurrent futures spawned when generating proofs for batch requests or when extracting transaction indexes from transaction hashes. 
# This will limited the maximum amount of parallel RPC calls made for a single API request, which can help prevent overwhelming the RPC endpoint and hitting rate limits. 
# Adjust based on expected load and RPC rate limits.
MAX_BATCH_SIZE=10

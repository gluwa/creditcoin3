      },
      {
        "allValue": ".+",
        "datasource": "$datasource",
        "label": "Select Attestor Job",
        "multi": true,
        "name": "job",
        "options": [],
        "query": "query_result(up{})",
        "refresh": 2,
        "regex": ".*job=\"(.*?)\".*",
        "type": "query"
      },
      {
        "allValue": ".+",
        "datasource": "$datasource",
        "definition": "query_result(up{})",
        "description": "",
        "label": "Select Attestor Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": {
          "qryType": 3,
          "query": "query_result(up{})",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "regex": ".*instance=\"(.*?)\".*",
        "type": "query"
      },
      {
        "allValue": ".+",
        "datasource": "$datasource",
        "definition": "label_values(cc3next_rpc_url,cc3next_rpc_url)",
        "hide": 2,
        "includeAll": false,
        "label": "Select CC3Next RPC URL",
        "multi": true,
        "name": "cc3next",
